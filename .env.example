# Authentication (required for all environments)
# Set a strong shared password for authorized SFG users.
APP_ACCESS_PASSWORD=replace-with-strong-password

# HMAC signing secret for session cookies (minimum 32 characters).
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-character-secret-minimum

# Local development only — skip login when NODE_ENV=development (never active in production).
LOCAL_AUTH_BYPASS=false
