# Authentication (required for all environments)
# Set a strong shared password for authorized SFG users.
APP_ACCESS_PASSWORD=replace-with-strong-password

# HMAC signing secret for session cookies (minimum 32 characters).
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-character-secret-minimum

# Local development only — skip login when NODE_ENV=development (never active in production).
LOCAL_AUTH_BYPASS=false

# Azure Blob Storage (required for PDF uploads over ~4 MB)
# Use a private container. Never expose the connection string to the client.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# Azure Document Intelligence OCR (server-side only)
OCR_PROVIDER=azure
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Developer OCR diagnostics in review API/UI (production requires this explicitly)
ENABLE_OCR_DEBUG=false
